@model IEnumerable<BookManagementApp.Models.Book>

@{
    ViewData["Title"] = "Danh sách Sách";
}

<h1>Danh sách Sách</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Thêm Sách Mới</a>
</p>

<form asp-action="Index" method="get" class="row g-3 mb-3">
    <div class="col-md-5">
        <input type="text" name="searchName" value="@ViewBag.SearchName" class="form-control" placeholder="Tìm theo tên sách" />
    </div>
    <div class="col-md-4">
        <select name="sortBy" class="form-select">
            <option value="">Sắp xếp mặc định</option>
            @if ((ViewBag.CurrentSort as string) == "price_asc")
            {
                <option value="price_asc" selected>Giá tăng dần</option>
            }
            else
            {
                <option value="price_asc">Giá tăng dần</option>
            }

            @if ((ViewBag.CurrentSort as string) == "price_desc")
            {
                <option value="price_desc" selected>Giá giảm dần</option>
            }
            else
            {
                <option value="price_desc">Giá giảm dần</option>
            }
        </select>
    </div>
    <div class="col-md-3">
        <button type="submit" class="btn btn-secondary">Lọc</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Xóa lọc</a>
    </div>
</form>

<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Id)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Name)
            </th>
            <th>
                Tác giả
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Price)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ImageUrl)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Description)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CreatedDate)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.Id)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Name)
                </td>
                <td>
                    @(item.Author?.Name ?? "-")
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Price)
                </td>
                <td>
                    @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                    {
                        <img src="@item.ImageUrl" alt="@item.Name" style="width: 60px; height: 80px; object-fit: cover;" />
                    }
                    else
                    {
                        <span>-</span>
                    }
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Description)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.CreatedDate)
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Sửa</a> |
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">Chi tiết</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Xóa</a>
                </td>
            </tr>
        }
    </tbody>
</table>
